{
  "contract_id": "finance-policy",
  "contract_version": "0.1.0",
  "description": "Governance rules for AI-driven financial actions",

  "rules": {
    "transfer": {
      "requires_approval": true,
      "approval_role": "human",
      "max_amount_without_additional_review": 10000
    },

    "get_balance": {
      "requires_approval": false,
      "read_only": true
    }
  },

  "invariants": {
    "separation_of_duties": [
      ["proposer", "approver"]
    ]
  }
}
